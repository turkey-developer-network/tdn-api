{
    "name": "tdn-api",
    "version": "0.0.1",
    "description": "TDN API",
    "private": true,
    "scripts": {
        "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
        "build": "tsc && tsc-alias",
        "start": "cross-env NODE_ENV=production node dist/index.js",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "prepare": "husky"
    },
    "keywords": [
        "tdn-api",
        "tdn",
        "fastify",
        "api"
    ],
    "author": "İrfan Sönmezışıklı",
    "license": "MIT",
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix",
            "prettier --write --ignore-unknown"
        ]
    },
    "prisma": {
        "schema": "prisma"
    },
    "packageManager": "pnpm@10.30.1",
    "dependencies": {
        "@fastify/env": "^5.0.3",
        "@fastify/type-provider-typebox": "^6.1.0",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@sinclair/typebox": "^0.34.48",
        "argon2": "^0.44.0",
        "fastify": "^5.8.1",
        "fastify-plugin": "^5.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.3.3",
        "cross-env": "^10.1.0",
        "dotenv": "^17.3.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "lint-staged": "^16.3.2",
        "pino-pretty": "^13.1.3",
        "prettier": "3.8.1",
        "prisma": "^7.4.2",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
