PORT=8080

# Database Configuration
# Example: postgresql://user:password@host:port/dbname?sslmode=verify-full
DATABASE_URL=

# JWT Configuration
ACCESS_TOKEN_SECRET_KEY=your_access_token_secret
ACCESS_TOKEN_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=1800

# Cookie Configuration
COOKIE_SECRET=your_cookie_secret

# Jobs Configuration
USER_PURGE_CRON="0 3 * * *"
USER_PURGE_GRACE_PERIOD_DAYS=30
REFRESH_TOKEN_PURGE_CRON="0 */6 * * *"
REFRESH_TOKEN_PURGE_GRACE_PERIOD_DAYS=1
NOTIFICATION_PURGE_CRON="* * * * *"
NOTIFICATION_PURGE_GRACE_PERIOD_DAYS=0

# Email Configuration
EMAIL_FROM="The Developer Network <contact@developernetwork.net>"
RESEND_API_KEY=resend_api_key

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# OAuth GitHub Configuration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/oauth/github/callback

# OAuth Google Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/oauth/google/callback

# R2 Configuration
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_PUBLIC_URL=https://your-public-url

# Redis Configuration
REDIS_URL=

#DEEP_API
DEEPL_API_KEY=dumplicate_deepl_api_key
