model Profile {
    id String @id @default(uuid())

    userId String @unique
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    fullName String
    bio String?
    location String?

    avatarUrl String @default("avatars/default_profile.png")
    bannerUrl String @default("banners/default_banner.jpg")

    socials Json? 

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("profiles")
}