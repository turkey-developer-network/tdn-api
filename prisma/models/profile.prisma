model Profile {
    id String @id @default(uuid())

    userId String @unique
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    fullName String
    bio String?
    location String?

    avatarUrl String @default("https://pub-2e6c13927ac24d548fd5b783e3cdaeb5.r2.dev/avatars/default_profile.png")
    bannerUrl String @default("https://pub-2e6c13927ac24d548fd5b783e3cdaeb5.r2.dev/avatars/default_banner.jpe")

    socials Json? 

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("profiles")
}